# Exemplo de variáveis de ambiente — COPIE para .env.local e preencha os valores reais
# O arquivo .env.local está no .gitignore e NUNCA deve ser commitado

# Supabase — Variáveis de SERVIDOR (sem NEXT_PUBLIC_, não vão para o browser)
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
